# Copy to .env and adjust. Used by docker-compose.yaml.

# --- Database container (Postgres + PostGIS) ---
POSTGRES_USER=flood
POSTGRES_PASSWORD=flood_secret
POSTGRES_DB=flood_warning
POSTGRES_PORT=5432

# --- NestJS API ---
# In docker-compose, DB_HOST is overridden to "db". Use "localhost" when
# running the app or migrations from the host machine.
DB_HOST=localhost
DB_PORT=5432
DB_USER=flood
DB_PASSWORD=flood_secret
DB_NAME=flood_warning
DB_LOGGING=false
API_PORT=3000

# Comma-separated list of browser origins allowed to call the API (CORS).
# Defaults to the local Vite dev server when unset.
CORS_ORIGINS=http://localhost:5173

# --- Auth / JWT ---
# Access token: short-lived (carries role + permissions for RBAC).
# Refresh token: long-lived, rotated on each /auth/refresh and revocable on logout.
JWT_ACCESS_SECRET=change_me_access_secret
JWT_ACCESS_TTL=900s
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_TTL=7d
BCRYPT_SALT_ROUNDS=12

# --- Redis ---
# Backs: refresh-token store (whitelist + per-user invalidation epoch), the
# internal Pub/Sub event bus, and the Socket.IO redis-adapter for horizontal
# scaling of the real-time gateway. In docker-compose REDIS_HOST is overridden
# to "redis"; use "localhost" when running the app from the host.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- Group F: third-party weather integration ---
# API keys. Open-Meteo & GDACS are keyless; OWM & WeatherAPI require a key —
# providers without a key are skipped in the fallback chain Open-Meteo → OWM →
# WeatherAPI (and reported as "not configured" by /integrations/health).
OPENWEATHERMAP_API_KEY=
WEATHERAPI_KEY=

# Shared secret guarding the scheduler-only POST /internal/weather/ingest (API 34),
# sent in the X-Internal-Token header. Endpoint is closed when this is unset.
INTERNAL_API_TOKEN=change_me_internal_token

# Cron schedules (node-cron syntax). Hourly ingestion + healthcheck pings.
WEATHER_CRON=0 * * * *
WEATHER_HEALTHCHECK_CRON=*/2 * * * *

# Forecast horizon (days) and per-provider HTTP timeout/retry.
WEATHER_FORECAST_DAYS=7
WEATHER_HTTP_TIMEOUT_MS=10000
WEATHER_HTTP_RETRIES=2

# Shorter timeout for /integrations/health liveness pings so a blocked/unreachable
# source (e.g. GDACS when network-blocked) doesn't stall the whole healthcheck.
WEATHER_PING_TIMEOUT_MS=5000

# Manual-refresh debounce lock TTL (ms) — blocks refresh spam (API 31).
WEATHER_REFRESH_LOCK_TTL_MS=30000

# Egress proxy for ALL weather calls (forward/HTTP-CONNECT proxy). Use when a
# source is unreachable from this network (e.g. GDACS blocked from some ISPs).
# Falls back to HTTPS_PROXY if unset. Leave empty for direct connections.
# WEATHER_PROXY_URL=http://user:pass@proxy-host:8080

# Optional base-URL overrides (defaults point at the public endpoints).
# OPEN_METEO_FORECAST_URL=https://api.open-meteo.com/v1/forecast
# OPEN_METEO_FLOOD_URL=https://flood-api.open-meteo.com/v1/flood
# OPENWEATHERMAP_FORECAST_URL=https://api.openweathermap.org/data/2.5/forecast
# WEATHERAPI_FORECAST_URL=https://api.weatherapi.com/v1/forecast.json
# GDACS_EVENTS_URL=https://www.gdacs.org/gdacsapi/api/events/geteventlist/EVENTS4APP

# NASA EONET — keyless, multi-hazard disaster-event source (severe storms, floods,
# volcanoes, wildfires…) with geometry; the directly-reachable alternative to GDACS
# when GDACS is network-blocked. Healthchecked alongside GDACS in /integrations/health.
# EONET_EVENTS_URL=https://eonet.gsfc.nasa.gov/api/v3/events?status=open&days=30
# No forward proxy? Route ONLY GDACS through a public read-proxy (DEV/TEST ONLY:
# slow + flaky). Use allorigins /raw — it returns the GDACS JSON unwrapped, whereas
# /get wraps it in {contents,status}. The proxy→GDACS hop intermittently returns
# Cloudflare 522; the GDACS ping retries (WEATHER_HTTP_RETRIES) to ride over those.
# If you enable this, raise WEATHER_PING_TIMEOUT_MS / WEATHER_HTTP_TIMEOUT_MS to
# ~20s/25s since the proxy adds ~12s latency:
# GDACS_EVENTS_URL=https://api.allorigins.win/raw?url=https://www.gdacs.org/gdacsapi/api/events/geteventlist/EVENTS4APP
